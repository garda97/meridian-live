{
  "name": "dlmm-agent",
  "version": "1.1.0",
  "type": "module",
  "description": "Autonomous Meteora DLMM LP agent for Solana — screening, rebalance, ops dashboard",
  "main": "index.js",
  "bin": {
    "meridian": "cli.js"
  },
  "scripts": {
    "setup": "node setup.js",
    "env:encrypt": "node scripts/envrypt.js encrypt",
    "start": "node index.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart meridian --update-env",
    "pm2:logs": "pm2 logs meridian --lines 100",
    "dev": "DRY_RUN=true node index.js",
    "test": "npm run test:syntax",
    "test:syntax": "find . -path ./node_modules -prune -o -name '*.js' -exec node --check {} \\;",
    "test:screen": "node test/test-screening.js",
    "test:agent": "DRY_RUN=true node test/test-agent.js",
    "helius:status": "node scripts/helius_keys.js status",
    "helius:validate": "node scripts/helius_keys.js validate",
    "helius:import": "node scripts/helius_keys.js import-backup",
    "dashboard": "PYTHONPATH=. python3 -m web.dashboard",
    "postinstall": "node scripts/patch-anchor.js"
  },
  "knip": {
    "ignore": [
      "discord-listener/**"
    ]
  },
  "dependencies": {
    "@meteora-ag/dlmm": "1.9.4",
    "@project-serum/anchor": "^0.26.0",
    "@solana/web3.js": "^1.98.4",
    "axios": "^1.18.1",
    "bn.js": "^5.2.1",
    "bs58": "^5.0.0",
    "dotenv": "^17.3.1",
    "jsonrepair": "^3.13.3",
    "node-cron": "^3.0.3",
    "openai": "^4.73.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
